# OkiDoki CRM — variables de entorno
# Copiar a .env.local (Next.js) y .env (Prisma CLI). Nunca commitear valores reales.

# --- Base de datos (PostgreSQL) ---
DATABASE_URL="postgresql://okidoki:okidoki@localhost:5432/okidoki_crm?schema=public"

# --- Auth.js / NextAuth (Google OAuth) ---
AUTH_SECRET=""                # generar con: npx auth secret
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Dominio de correo autorizado: cualquier cuenta Google de este dominio entra
# (decisión de negocio; sin roles en el MVP):
ALLOWED_EMAIL_DOMAIN="okidokicr.com"

# --- Integración con CorrespondencyBot (generación de documentos) ---
# Ruta local al repo del bot de cotizaciones (subprocess en el MVP):
CORRESPONDENCY_BOT_PATH="/Users/garze/Code/CorrespondencyBot"
# Intérprete de Python del venv del bot:
CORRESPONDENCY_BOT_PYTHON="python3"
# Carpeta donde el CRM guarda los PDFs/DOCX generados:
DOCUMENTS_OUTPUT_DIR="./storage/documents"

# --- Google Maps (transporte) — mismas llaves que usa el bot ---
GOOGLE_MAPS_API_KEY=""

# --- Jobs programados (recordatorios y vencimientos) ---
# Token que protege POST /api/jobs/* (cron externo o Vercel Cron):
CRON_SECRET=""

# --- Referencia USD (opcional; si falta, no se muestra conversión) ---
# Tipo de cambio manual de respaldo CRC por USD:
USD_EXCHANGE_RATE_FALLBACK="520"
