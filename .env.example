# OkiDoki CRM — variables de entorno (Next.js)
# Copie este archivo a .env.local y complete los valores reales. Nunca commitear .env.local.

# --- Base de datos del CRM (PostgreSQL) ---
DATABASE_URL="postgresql://okidoki:okidoki@localhost:5432/okidoki_crm?schema=public"

# --- Auth.js / NextAuth (Google OAuth) ---
AUTH_SECRET=""          # generar con: npx auth secret
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Dominio de correo autorizado para acceder al CRM:
ALLOWED_EMAIL_DOMAIN="okidokicr.com"

# IMPORTANTE — AUTH_GOOGLE_ID es compartido con la Quotation API:
# El mismo Client ID va en GOOGLE_OAUTH_CLIENT_ID del .env de la Quotation API.
# El CRM emite el ID token con este audience; la API lo verifica contra ese mismo valor.
# AUTH_GOOGLE_SECRET es exclusivo del CRM y nunca va en la Quotation API.

# --- Quotation API (generación de cotizaciones y documentos) ---
# Servicio separado (Python/FastAPI). No llama a Google Maps ni a Google Sheets
# directamente — eso lo hace la Quotation API internamente.
# En desarrollo: http://localhost:8000 (uvicorn api:app --reload)
# En producción: URL pública del servicio desplegado.
QUOTATION_API_URL="http://localhost:8000"

# --- Jobs programados (recordatorios y vencimientos) ---
# Token que protege POST /api/jobs/* (cron externo o Vercel Cron):
CRON_SECRET=""

# --- Referencia USD (opcional; si falta, no se muestra conversión) ---
USD_EXCHANGE_RATE_FALLBACK="520"
